# ARCA backend — environment template. Copy to .env and fill in.
# Real secrets live ONLY in host dashboards (Render) and GitHub Actions secrets. NEVER commit .env.
#
# Local dev needs NONE of these — `./mvnw spring-boot:test-run` uses an embedded Postgres.
# The variables below are for the `prod` profile (Render), which talks to Neon + Supabase.

# ---- Activate the production profile ----
SPRING_PROFILES_ACTIVE=prod

# ---- Database: Neon PostgreSQL (JDBC URL; Neon requires SSL) ----
DATABASE_URL=jdbc:postgresql://<your-neon-host>/<db>?sslmode=require
DATABASE_USERNAME=<neon-user>
DATABASE_PASSWORD=<neon-password>
DB_POOL_MAX_SIZE=5

# ---- Auth (JWT) ----
JWT_SECRET=change-me-use-a-long-random-string-at-least-32-chars
JWT_EXPIRATION_MS=3600000

# ---- CORS: the Vercel frontend origin(s), comma-separated ----
CORS_ALLOWED_ORIGINS=https://<your-app>.vercel.app

# ---- Receipts: Supabase Storage (private bucket) ----
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me-server-side-only
SUPABASE_STORAGE_BUCKET=receipts
SUPABASE_SIGNED_URL_EXPIRY=3600

# ---- Frontend build-time var (set on Vercel, documented in frontend/.env.example) ----
# API_BASE_URL=https://<your-render-app>.onrender.com
