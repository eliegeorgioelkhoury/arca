# ARCA — environment template. Copy to .env and fill in.
# Real secrets live ONLY in host dashboards and GitHub Actions secrets. Never commit .env.

# ---- Backend: database (Neon PostgreSQL) ----
DATABASE_URL=postgresql://user:password@localhost:5432/arca
DATABASE_USERNAME=arca
DATABASE_PASSWORD=change-me

# ---- Backend: auth ----
JWT_SECRET=change-me-use-a-long-random-string
JWT_EXPIRATION_MS=3600000

# ---- Backend: receipts (Supabase Storage) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me-server-side-only
SUPABASE_STORAGE_BUCKET=receipts

# ---- Frontend (Angular) ----
NG_APP_API_BASE_URL=http://localhost:8080
